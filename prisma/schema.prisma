generator client {

  provider = "prisma-client-js"

  output   = "../src/generated/prisma"

}



datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}



model Section {

  id        String   @id @default(cuid())

  key       String   @unique

  content   Json

  updatedAt DateTime @updatedAt

}

model Account {

  id                String  @id @default(cuid())

  userId            String

  type              String

  provider          String

  providerAccountId String

  refresh_token     String? @db.Text

  access_token      String? @db.Text

  expires_at        Int?

  token_type        String?

  scope             String?

  id_token          String? @db.Text

  session_state     String?



  user User @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@unique([provider, providerAccountId])

}



model Session {

  id           String   @id @default(cuid())

  sessionToken String   @unique

  userId       String

  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}



model Purchase {

  id        String   @id @default(cuid())

  userId    String

  productId String   // np. "ebook-tom-1"

  createdAt DateTime @default(now())



  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@unique([userId, productId]) // Zabezpieczenie: Jeden użytkownik może mieć tylko jedną sztukę danego produktu

}



model Order {

  id              String   @id @default(cuid())

  userId          String

  amount          Int      // w groszach

  currency        String

  status          String   // "pending", "succeeded", "failed"

  paymentIntentId String   @unique

  createdAt       DateTime @default(now())
 
  fakturowniaId     Int?     // ID w ich systemie (potrzebne do API)

  invoiceNumber     String?

  // --- DANE DO FAKTURY (SNAPSHOT) ---

  billingType       String   @default("personal") // "personal" lub "company"

  billingName       String   @default("")

  billingNip        String?  

  billingAddress    String   @default("")

  billingCity       String   @default("")

  billingPostalCode String   @default("")

  billingCountry    String   @default("PL")

 

  // --- PLIKI FAKTUR ---

  // Teraz przechowujemy dwa linki (np. do AWS S3 / Vercel Blob)

  invoicePdfUrl     String?  // Link do wersji czytelnej dla człowieka

  invoiceXmlUrl     String?  // Link do wersji strukturalnej (np. dla księgowości/KSeF)

 

  // Opcjonalnie: Numer nadany przez KSeF (przydatne w B2B)

  ksefNumber        String?



  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}

model UserProgress {

  id        String   @id @default(cuid())

  userId    String

  chapterId String   // Tutaj będziemy zapisywać "slug" pliku (np. "01-wstep")

  updatedAt DateTime @updatedAt // Data ostatniego odczytu



  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@unique([userId, chapterId]) // Użytkownik może mieć tylko jeden wpis dla danego rozdziału

}



model User {

  id            String    @id @default(cuid())

  name          String?

  email         String?   @unique

  // DODAJ TO POLE, ABY ADAPTER PRZESTAŁ KRZYCZEĆ:

  emailVerified DateTime?

  image         String?

  role          String    @default("client")

  accounts      Account[]

  sessions      Session[]

  purchases Purchase[]

  orders    Order[]

  progress UserProgress[]

  reviews   Review[]

}



model Review {

  id        String   @id @default(cuid())

  rating    Int      // 1-5

  comment   String?  @db.Text

  createdAt DateTime @default(now())

 

  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}



model VerificationToken {

  identifier String

  token      String   @unique

  expires    DateTime



  @@unique([identifier, token])

} 

model News {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  published   Boolean  @default(true) // Czy widoczne dla userów
  important   Boolean  @default(false) // Czy to "ważne" powiadomienie (np. czerwony alert)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}